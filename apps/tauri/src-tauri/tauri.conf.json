{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Plutus",
  "version": "0.1.0",
  "identifier": "com.eunsoogi.plutus",
  "build": {
    "beforeDevCommand": "pnpm --filter @plutus/web-preview dev",
    "devUrl": "http://localhost:4173",
    "beforeBuildCommand": "pnpm --filter @plutus/web-preview build",
    "frontendDist": "../../web-preview/dist"
  },
  "app": {
    "windows": [
      {
        "title": "Plutus",
        "width": 1440,
        "height": 960,
        "minWidth": 1100,
        "minHeight": 720
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": []
  }
}
